rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid is string 
        && data.name is string && data.name.size() <= 100
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 50;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.creatorId == request.auth.uid
        && data.status in ['open', 'closed'];
    }

    // --- Collection Routes ---
    
    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Connections collection
    match /connections/{connectionId} {
      allow read: if isSignedIn(); // Allow list for graph/searching
      allow create: if isSignedIn() && (incoming().userA == request.auth.uid || incoming().userB == request.auth.uid);
      allow update, delete: if isSignedIn() && (existing().userA == request.auth.uid || existing().userB == request.auth.uid);
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().creatorId == request.auth.uid && isValidProject(incoming());
      allow update, delete: if isSignedIn() && existing().creatorId == request.auth.uid;
    }

    // Nuclei (readonly for users)
    match /nuclei/{nucleusId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}